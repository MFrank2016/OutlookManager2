# 远程 PostgreSQL 兼容模板。
#
# 这不是当前仓库的主启动入口。
# - 本地 Docker Compose 栈：使用 `.env.compose.local`
# - 远程 PostgreSQL / 只跑后端：优先使用 `.env.remote-db.example`
#
# 仅当历史脚本或旧文档仍要求 `.env` 文件名时，才参考本模板。

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
TZ=Asia/Shanghai

DB_TYPE=postgresql
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=outlook_manager
DB_USER=outlook_user
DB_PASSWORD=your_remote_password_here

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=15
DB_POOL_TIMEOUT=30
