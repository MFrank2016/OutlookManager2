# **历史兼容**：这个文件只为旧 `.env` 方案和历史说明保留。
# 当前 compose 主路径请使用 `.env.compose.local`，不要把这里当成首启入口。
#
# 推荐路径：
# - 首次启动：看 `README.md`
# - 本地 compose 运维：看 `README_DOCKER.md`
# - 远程 PostgreSQL / 只跑后端：复制 `.env.remote-db.example` 为 `.env`

HOST=0.0.0.0
PORT=8000
FRONTEND_PORT=3000
LOG_LEVEL=info
TZ=Asia/Shanghai

PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1

# 历史上旧 `.env` 方案里可能会出现这些字段。
# 如无明确旧脚本兼容需求，请优先参考 `.env.compose.example` 或 `.env.remote-db.example`。
DB_TYPE=postgresql
DB_HOST=postgresql
DB_PORT=5432
DB_NAME=outlook_manager
DB_USER=outlook_user
DB_PASSWORD=changeme

POSTGRES_DB=outlook_manager
POSTGRES_USER=outlook_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
