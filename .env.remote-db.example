# 远程 PostgreSQL 模式示例配置
# 使用方式：
#   cp .env.remote-db.example .env
#   python main.py
#
# 注意：
# - 这套配置给“直接运行 Python 服务”用
# - 不要和本地 compose 栈混用

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
TZ=Asia/Shanghai

DB_TYPE=postgresql
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=outlook_manager
DB_USER=outlook_user
DB_PASSWORD=your_remote_password_here

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=15
DB_POOL_TIMEOUT=30
