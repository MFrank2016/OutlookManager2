# 本地 Docker Compose 栈示例配置
# 使用方式：
#   cp .env.compose.example .env.compose.local
#   docker compose --env-file .env.compose.local up -d --build

# 对外暴露端口
PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=55432

# 通用配置
TZ=Asia/Shanghai
LOG_LEVEL=info

# 本地 PostgreSQL 容器配置
POSTGRES_DB=outlook_manager
POSTGRES_USER=outlook_user
POSTGRES_PASSWORD=changeme

# API 容器连接池
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=15
DB_POOL_TIMEOUT=30
